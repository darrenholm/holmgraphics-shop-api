# .env — copy this to .env and fill in your values
# NEVER commit .env to git

# Railway Postgres connection string.
# Local dev: use the PUBLIC proxy URL from Railway dashboard
#   (Postgres service → Connect → DATABASE_PUBLIC_URL, ends in .rlwy.net).
# In production on Railway, this is auto-injected when the Postgres
# plugin is attached — do NOT set it manually in the service.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway

# JWT secret — change this to something long and random
JWT_SECRET=holmgraphics-change-this-to-something-random-2026

# JWT expiry
JWT_EXPIRES_IN=8h

# Server port
PORT=3000

# Allowed frontend origins (comma-separated)
# Local dev + your production hosting
CORS_ORIGINS=http://localhost:5173,https://holmgraphics.ca,https://www.holmgraphics.ca

# ─── QuickBooks Online (Intuit) OAuth2 credentials ───────────────────────────
# From Intuit Developer dashboard → your app → Keys & OAuth.
# NODE_ENV=production switches the API target from sandbox to live QB.
# Leave these blank if QB integration isn't in use — the /quickbooks/*
# routes will just return "QuickBooks not connected" errors.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://holmgraphics-shop-api-production.up.railway.app/api/quickbooks/callback
