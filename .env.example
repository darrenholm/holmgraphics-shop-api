# .env — copy this to .env and fill in your values
# NEVER commit .env to git

# Railway Postgres connection string.
# Local dev: use the PUBLIC proxy URL from Railway dashboard
#   (Postgres service → Connect → DATABASE_PUBLIC_URL, ends in .rlwy.net).
# In production on Railway, this is auto-injected when the Postgres
# plugin is attached — do NOT set it manually in the service.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway

# JWT secret — change this to something long and random
JWT_SECRET=holmgraphics-change-this-to-something-random-2026

# JWT expiry
JWT_EXPIRES_IN=8h

# Server port
PORT=3000

# Allowed frontend origins (comma-separated). Order does not matter;
# the CORS check is a flat membership test (server.js).
# Include every host that should be able to call the API:
#   • localhost for dev
#   • the apex (customer + marketing)
#   • the www apex (will 301 to apex but origin is still sent)
#   • the staff subdomain
#   • the .pages.dev URL Cloudflare assigns the project (preview deploys)
CORS_ORIGINS=http://localhost:5173,https://holmgraphics.ca,https://www.holmgraphics.ca,https://shop.holmgraphics.ca,https://holmgraphics-shop.pages.dev

# Customer-facing base URL — used in proof / order emails to build links
# back into the shop. Defaults to https://shop.holmgraphics.ca for
# legacy compatibility; set this to the apex now that customer routes
# live there.
PUBLIC_SHOP_URL=https://holmgraphics.ca

# Staff app base URL — used by routes/quickbooks.js to redirect users
# back to the QB admin page after the OAuth callback completes.
STAFF_APP_URL=https://shop.holmgraphics.ca

# ─── Resend (transactional email) ────────────────────────────────────────────
# lib/customer-mailer.js sends activation, password reset, order
# confirmation, proof, shipping, and refund emails through Resend's
# REST API. Without RESEND_API_KEY the mailer falls back to console-only
# logging — fine for local dev, NOT fine for production.
#
# Setup (one-time):
#   1. Resend dashboard → Domains. If holmgraphics.ca isn't already
#      verified for the other project on this account, add it (Resend
#      walks you through 2 DNS records: SPF TXT + DKIM TXT).
#   2. Resend → API Keys → create a key with "Sending access" scope.
#      Copy the key here.
#
# SHOP_FROM_EMAIL must be a verified sender on the verified domain
# (e.g. orders@holmgraphics.ca). The "Holm Graphics <...>" prefix is
# the display name customers see in their inbox.
#
# SHOP_REPLY_TO is optional — set this if you want replies routed to
# a different inbox than the From: address.
RESEND_API_KEY=
SHOP_FROM_EMAIL=Holm Graphics <orders@holmgraphics.ca>
SHOP_REPLY_TO=

# Where new quote-request submissions from the homepage form get sent.
# Defaults to the address inside SHOP_FROM_EMAIL if unset.
SHOP_QUOTES_TO=orders@holmgraphics.ca

# ─── QuickBooks Online (Intuit) OAuth2 credentials ───────────────────────────
# From Intuit Developer dashboard → your app → Keys & OAuth.
# NODE_ENV=production switches the API target from sandbox to live QB.
# Leave these blank if QB integration isn't in use — the /quickbooks/*
# routes will just return "QuickBooks not connected" errors.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://holmgraphics-shop-api-production.up.railway.app/api/quickbooks/callback

# ─── WHC photo storage (FTPS) ────────────────────────────────────────────────
# Job photos live on WHC's cPanel hosting because Railway's filesystem is
# ephemeral (wiped on redeploy). Uploaded files stream through the API to
# public_html/shop-uploads/jobs/<project_id>/ and are served publicly from
# WHC_PUBLIC_BASE (which should point at the same folder via the website).
#
# From cPanel → FTP Accounts. Use a dedicated account scoped to the
# shop-uploads folder, NOT your main cPanel login.
WHC_FTP_HOST=ftp.holmgraphics.ca
WHC_FTP_PORT=21
WHC_FTP_USER=shop@shop.holmgraphics.ca
WHC_FTP_PASSWORD=
# Explicit FTPS (AUTH TLS on port 21). Set to "false" only if the server
# truly doesn't support TLS — plain FTP sends credentials in the clear.
WHC_FTP_SECURE=true
# Remote path, relative to the FTP user's home dir.
WHC_REMOTE_BASE=public_html/shop-uploads/jobs
# Public URL that maps to the same folder on the live site.
WHC_PUBLIC_BASE=https://holmgraphics.ca/shop-uploads/jobs

# ─── SanMar Canada (PromoStandards + Bulk Data) ──────────────────────────────
# Account #26562. PromoStandards services + SanMar-specific Bulk Data.
# UAT/sandbox uses your SanMar login; prod needs ticket to activate.
# Media Content service has its own password — set from SanMar email.
# Bulk Data sandbox is a shared id/pwd; real creds arrive separately.
SANMAR_ENV=uat
SANMAR_USERNAME=
SANMAR_PASSWORD=
SANMAR_MEDIA_PASSWORD=
SANMAR_BULK_DATA_ID=
SANMAR_BULK_DATA_PASSWORD=

# ─── Canada Sportswear (PromoStandards) ──────────────────────────────────────
# Credentials pending. Once the onboarding packet arrives, fill these and
# the endpoint URLs in suppliers/canada_sportswear/config.js.
CANADA_SPORTSWEAR_ENV=uat
CANADA_SPORTSWEAR_USERNAME=
CANADA_SPORTSWEAR_PASSWORD=

# ─── S&S Activewear (PromoStandards) ─────────────────────────────────────────
# Credentials pending.
SS_ACTIVEWEAR_ENV=uat
SS_ACTIVEWEAR_USERNAME=
SS_ACTIVEWEAR_PASSWORD=

# ─── AlphaBroder (PromoStandards) ────────────────────────────────────────────
# Credentials pending.
ALPHA_BRODER_ENV=uat
ALPHA_BRODER_USERNAME=
ALPHA_BRODER_PASSWORD=
